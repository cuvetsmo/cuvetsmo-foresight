# Foresight — public env vars (read at build/runtime by Next.js).
#
# Copy to .env.local for local dev, or set in Vercel project settings for
# deployed environments. All NEXT_PUBLIC_* values are baked into the client
# bundle; do not put secrets here.

# Canonical absolute URL of the deployment (no trailing slash). Used for
# metadata, JSON-LD, sitemap, OG images. Change this and DNS to spin off.
NEXT_PUBLIC_BASE_URL=https://foresight.cuvetsmo.com

# Whether to render the cross-product navigation bar at the top of every
# page. "false" by default — set to "true" only when this surface is
# part of a multi-product family that wants to show siblings.
NEXT_PUBLIC_SHOW_ECOSYSTEM_BAR=false

# X / Twitter handle without the @ — used in OG metadata and footer.
# Leave empty to hide social links entirely.
NEXT_PUBLIC_X_HANDLE=

# Supabase backend (shared with the cuvetsmo main project).
# Reads from public.foresight_* tables. If unset, the app falls back to
# the bundled seed in lib/markets-seed.ts so the landing never blanks.
NEXT_PUBLIC_SUPABASE_URL=https://snmjxaydjykosdzxwjnv.supabase.co
# Use the LEGACY anon JWT (eyJ...). Edge functions with verify_jwt=true
# reject sb_publishable_* keys — see memory rule
# reference_supabase-publishable-key-not-jwt.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
